generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPERADMIN
  ADMIN
  INTERMEDIARIO
  LEGAL
  LOGISTICA
}

enum Plan {
  FREE
  STARTER
  PRO
  BUSINESS
  ENTERPRISE
}

enum CandidateStatus {
  RECOPILANDO_DOCS
  DOCUMENTACION_PENDIENTE
  EN_REVISION_LEGAL
  REVISION_ADICIONAL
  APROBADO
  RECHAZADO
  EN_PROCESO_PERMISO
  CONTRATADO
  RETIRADO
}

enum LocationStatus {
  EN_ORIGEN
  EN_TRANSITO
  EN_POLONIA
}

enum DocumentType {
  PASSPORT
  KARTA_POBYTU
  PESEL
  DECYZJA_WOJEWODY
  VISA
  ENTRY_STAMP
  EXIT_STAMP
  PAYMENT_RECEIPT
  CV
  OTHER
}

enum RecruitmentSource {
  WHATSAPP
  EMAIL
  REFERRAL
  GOOGLE_ADS
  WEBSITE
  OTHER
}

enum BrokerType {
  PROVIDER
  MIXED
  UNKNOWN
}

enum BrokerStatus {
  NEW
  TESTING
  ACTIVE
  LOW_PERFORMANCE
  PAUSED
  REJECTED
}

enum BrokerLeadType {
  PROVIDER
  CANDIDATE
  UNKNOWN
}

enum BrokerContactChannel {
  EMAIL
  WHATSAPP
  CALL
  OTHER
}

enum BrokerInvoiceStatus {
  DRAFT
  READY
  SENT
  PAID
  DISPUTED
}

model Organization {
  id       String  @id @default(cuid())
  name     String
  slug     String  @unique
  taxId    String?
  country  String?
  plan     Plan    @default(FREE)
  isActive Boolean @default(true)

  logoUrl        String?
  primaryColor   String?
  secondaryColor String?

  referralCode String? @unique
  referredById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  referredBy Organization?  @relation("Referrals", fields: [referredById], references: [id])
  referrals  Organization[] @relation("Referrals")

  users                 User[]
  memberships           Membership[]
  candidates            Candidate[]
  documents             Document[]
  auditLogs             AuditLog[]
  logisticsEvents       LogisticsEvent[]
  notifications         Notification[]
  statusHistories       StatusHistory[]
  subscription          Subscription?
  apiKeys               ApiKey[]
  workflows             Workflow[]
  leads                 Lead[]
  Outreach              Outreach[]
  brokers               Broker[]
  brokerLeads           BrokerLead[]
  brokerContactAttempts BrokerContactAttempt[]
  workerReferrals       WorkerReferral[]
  brokerInvoices        BrokerInvoice[]
  brokerInvoiceLines    BrokerInvoiceLine[]
}

model Membership {
  id             String  @id @default(cuid())
  userId         String
  organizationId String
  role           Role    @default(INTERMEDIARIO)
  isActive       Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@index([userId])
}

model User {
  id              String  @id @default(cuid())
  email           String  @unique
  name            String?
  passwordHash    String?
  role            Role    @default(INTERMEDIARIO)
  isActive        Boolean @default(true)
  settings        Json?   @default("{}")
  isPlatformAdmin Boolean @default(false)

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  memberships         Membership[]
  candidates          Candidate[]
  auditLogs           AuditLog[]
  notifications       Notification[]
  assignedBrokerLeads BrokerLead[]   @relation("BrokerLeadAssignedOwner")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Candidate {
  id             String         @id @default(cuid())
  firstName      String?
  lastName       String?
  email          String?
  phone          String?
  gender         String?
  dateOfBirth    DateTime?
  birthPlace     String?
  birthCountry   String?
  citizenship    String?
  nationality    String?
  heightCm       Int?
  country        String         @default("COL")
  locationStatus LocationStatus @default(EN_ORIGEN)
  polishAddress  String?
  polishCity     String?

  passportNumber    String?
  passportIssueDate DateTime?
  passportExpiry    DateTime?
  passportBiometric Boolean?

  kartaPobytuNumber    String?
  kartaPobytuIssueDate DateTime?
  kartaPobytuExpiry    DateTime?
  kartaPobytuType      String?

  peselNumber String?

  voivodatoNumber    String?
  voivodatoIssueDate DateTime?
  voivodatoExpiry    DateTime?
  voivodatoStatus    String?

  recruitmentSource RecruitmentSource?
  recruiterId       String?

  arrivalDate        DateTime?
  accommodation      String?
  accommodationNotes String?
  arrivalNotes       String?

  status          CandidateStatus @default(RECOPILANDO_DOCS)
  rejectionReason String?
  notes           String?

  paid400pln  Boolean   @default(false)
  paymentDate DateTime?

  gdprConsent     Boolean   @default(false)
  gdprConsentDate DateTime?

  intermediaryId String
  intermediary   User   @relation(fields: [intermediaryId], references: [id])

  selfRegistered    Boolean @default(false)
  registrationToken String? @unique

  ocrProcessed Boolean @default(false)
  ocrSource    String?

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  dataRetentionUntil DateTime?
  isArchived         Boolean   @default(false)
  reviewNotes        String?

  score          Int?
  scoreLevel     String?
  scoreUpdatedAt DateTime?

  documents     Document[]
  logistics     LogisticsEvent[]
  notifications Notification[]
  statusHistory StatusHistory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([id, organizationId])
  @@index([organizationId, email])
}

model Document {
  id            String       @id @default(cuid())
  type          DocumentType
  number        String?
  issuerCountry String?
  issueDate     DateTime?
  expiryDate    DateTime?
  url           String
  extractedData Json?
  isVerified    Boolean      @default(false)
  verifiedById  String?
  ocrStatus     String?

  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([id, organizationId])
}

model LogisticsEvent {
  id          String   @id @default(cuid())
  type        String
  description String?
  date        DateTime @default(now())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  transportType String?
  arrivalDate   DateTime?
  terminal      String?
  flightOrTrain String?
  pickedUpBy    String?
  confirmed     Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([id, organizationId])
}

model StatusHistory {
  id          String          @id @default(cuid())
  fromStatus  CandidateStatus
  toStatus    CandidateStatus
  reason      String?
  changedById String

  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([id, organizationId])
}

model AuditLog {
  id         String  @id @default(cuid())
  action     String
  entityType String
  entityId   String
  userId     String?
  details    Json?

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  User      User?    @relation(fields: [userId], references: [id])

  @@unique([id, organizationId])
}

model Notification {
  id      String  @id @default(cuid())
  type    String
  title   String
  message String
  isRead  Boolean @default(false)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  candidateId String?
  candidate   Candidate? @relation(fields: [candidateId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@unique([id, organizationId])
}

model Subscription {
  id             String       @id @default(cuid())
  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  plan               Plan
  status             String
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?

  provider               String?
  providerCustomerId     String?
  providerSubscriptionId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([id, organizationId])
}

model ApiKey {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name       String
  keyHash    String
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())
}

model Workflow {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name        String
  isActive    Boolean @default(true)
  triggerType String

  steps WorkflowStep[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([id, organizationId])
}

model WorkflowStep {
  id         String   @id @default(cuid())
  workflowId String
  workflow   Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  type   String
  config Json
  order  Int
}

model Lead {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name    String
  email   String?
  phone   String?
  company String?
  status  String  @default("NEW")
  source  String?
  notes   String?

  outreaches Outreach[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([id, organizationId])
}

model Outreach {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  step    Int
  message String
  sentAt  DateTime?
  reply   String?

  createdAt DateTime @default(now())

  @@unique([id, organizationId])
}

model Broker {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  displayName          String
  legalOrBillingName   String?
  country              String?
  city                 String?
  primaryEmail         String?
  primaryPhone         String?
  declaredSupplyText   String?
  declaredWeeklyVolume Int?
  brokerType           BrokerType   @default(UNKNOWN)
  status               BrokerStatus @default(NEW)
  qualityRating        Int?
  notes                String?

  leads     BrokerLead[]
  referrals WorkerReferral[]
  invoices  BrokerInvoice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, displayName])
  @@index([organizationId, displayName])
}

model BrokerLead {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  brokerId String?
  broker   Broker? @relation(fields: [brokerId], references: [id], onDelete: SetNull)

  sourceCountrySheet String
  sourceFileName     String?
  sourceRowHash      String
  leadDate           DateTime?
  firstName          String?
  lastName           String?
  email              String?
  phone              String?
  city               String?
  declaredSupplyText String?
  rawStatus          String?
  normalizedStatus   String?
  flowStatus         String?
  flowSentDate       DateTime?
  emailStatus        String?
  deliveryError      String?
  leadType           BrokerLeadType @default(UNKNOWN)
  lastReplyDate      DateTime?
  assignedOwnerId    String?
  assignedOwner      User?          @relation("BrokerLeadAssignedOwner", fields: [assignedOwnerId], references: [id], onDelete: SetNull)
  notes              String?

  contactAttempts BrokerContactAttempt[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, sourceCountrySheet, sourceRowHash])
  @@index([organizationId, sourceCountrySheet])
  @@index([organizationId, leadType])
  @@index([organizationId, rawStatus])
}

model BrokerContactAttempt {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  brokerLeadId String
  brokerLead   BrokerLead @relation(fields: [brokerLeadId], references: [id], onDelete: Cascade)

  attemptNo    Int
  channel      BrokerContactChannel @default(OTHER)
  contactDate  DateTime?
  result       String?
  summary      String?
  nextStep     String?
  nextStepDate DateTime?
  createdAt    DateTime             @default(now())

  @@unique([brokerLeadId, attemptNo])
  @@index([organizationId, brokerLeadId])
}

model WorkerReferral {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  brokerId String
  broker   Broker @relation(fields: [brokerId], references: [id], onDelete: Cascade)

  workerFullName        String
  workerStatusRaw       String?
  cycleLengthDays       Int?
  hoursWorked           Decimal?  @db.Decimal(10, 2)
  minimumHoursThreshold Int?
  minimumHoursMet       Boolean?
  ratePerPersonPln      Decimal?  @db.Decimal(10, 2)
  baseAmount            Decimal?  @db.Decimal(10, 2)
  vatRate               Decimal?  @db.Decimal(5, 4)
  finalAmount           Decimal?  @db.Decimal(10, 2)
  notes                 String?
  referencePeriodStart  DateTime?
  referencePeriodEnd    DateTime?
  sourceInvoiceSheet    String?
  sourceFileName        String?
  sourceRowHash         String?

  invoiceLines BrokerInvoiceLine[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, brokerId, workerFullName, sourceInvoiceSheet, referencePeriodStart, referencePeriodEnd])
  @@index([organizationId, brokerId])
  @@index([organizationId, sourceInvoiceSheet])
}

model BrokerInvoice {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  brokerId               String
  broker                 Broker              @relation(fields: [brokerId], references: [id], onDelete: Cascade)
  sourceInvoiceSheet     String
  sourceFileName         String?
  referencePeriodStart   DateTime?
  referencePeriodEnd     DateTime?
  invoiceType            String?
  ratePerPersonPln       Decimal?            @db.Decimal(10, 2)
  minimumHoursThreshold  Int?
  candidateCountEligible Int                 @default(0)
  baseTotal              Decimal             @default(0) @db.Decimal(12, 2)
  vatRate                Decimal?            @db.Decimal(5, 4)
  vatAmount              Decimal             @default(0) @db.Decimal(12, 2)
  finalAmount            Decimal             @default(0) @db.Decimal(12, 2)
  currency               String              @default("PLN")
  status                 BrokerInvoiceStatus @default(DRAFT)
  notes                  String?
  summaryBaseTotal       Decimal?            @db.Decimal(12, 2)
  summaryVatAmount       Decimal?            @db.Decimal(12, 2)
  summaryFinalAmount     Decimal?            @db.Decimal(12, 2)
  summaryCandidateCount  Int?
  summaryMismatchWarning String?

  lines BrokerInvoiceLine[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, sourceInvoiceSheet, referencePeriodStart, referencePeriodEnd])
  @@index([organizationId, brokerId])
  @@index([organizationId, status])
}

model BrokerInvoiceLine {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  brokerInvoiceId String
  brokerInvoice   BrokerInvoice @relation(fields: [brokerInvoiceId], references: [id], onDelete: Cascade)

  workerReferralId String?
  workerReferral   WorkerReferral? @relation(fields: [workerReferralId], references: [id], onDelete: SetNull)

  workerFullName        String
  workerStatusRaw       String?
  cycleLengthDays       Int?
  hoursWorked           Decimal? @db.Decimal(10, 2)
  minimumHoursThreshold Int?
  eligible              Boolean?
  rateApplied           Decimal? @db.Decimal(10, 2)
  baseAmount            Decimal? @db.Decimal(10, 2)
  vatRate               Decimal? @db.Decimal(5, 4)
  finalAmount           Decimal? @db.Decimal(10, 2)
  notes                 String?
  sourceRowHash         String

  @@unique([brokerInvoiceId, sourceRowHash])
  @@index([organizationId, brokerInvoiceId])
  @@index([brokerInvoiceId, workerFullName])
}
