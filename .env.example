# DATABASE
# Recommended local dev path: docker-compose Postgres
DB_USER="folga"
DB_PASSWORD="change-this-password"
DB_NAME="folga_hub"
DATABASE_URL="postgresql://folga:folga123@localhost:5432/folga_hub?schema=public"

# Alternative if you use the Windows Postgres service on this machine:
# DATABASE_URL="postgresql://your-user:your-password@localhost:5433/folga_hub?schema=public"

# AUTH
AUTH_URL="http://localhost:3000"
AUTH_SECRET="your-auth-secret-min-32-chars"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-auth-secret-min-32-chars"

# SUPABASE (STORAGE)
STORAGE_PROVIDER="supabase"
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="your-publishable-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
SUPABASE_STORAGE_BUCKET="documentos-candidatos"

# OCR (AZURE DOCUMENT INTELLIGENCE)
OCR_PROVIDER="azure"
AZURE_DI_ENDPOINT="https://your-resource.cognitiveservices.azure.com/"
AZURE_DI_KEY="your-azure-key"

# EMAIL DELIVERY (SMTP)
# Without these values, invitations are created but shown with a manual temporary password.
EMAIL_PROVIDER="smtp"
SMTP_HOST="smtp.your-provider.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-smtp-user"
SMTP_PASS="your-smtp-password"
SMTP_FROM="no-reply@your-domain.com"
SMTP_FROM_NAME="ORI CRUIT HUB"
# Only use true for trusted local test SMTP servers without STARTTLS.
SMTP_ALLOW_INSECURE="false"

# LOCAL/PRODUCTION MODE
NODE_ENV="development"
JOB_PROVIDER="inline"
CRON_SECRET="your-random-cron-secret-min-32-chars"

# HOSTINGER PRODUCTION NOTES
# On the VPS, keep DATABASE_URL managed by docker-compose.prod.yml.
# Set AUTH_URL and NEXTAUTH_URL to your HTTPS domain.
# Set SMTP_* to real provider values before inviting users.

# STRIPE (OPTIONAL UNTIL DISTRIBUTION PHASE)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_CUSTOMER_PORTAL_URL=""
STRIPE_PAYMENT_LINK_STARTER=""
STRIPE_PAYMENT_LINK_PRO=""
STRIPE_PAYMENT_LINK_BUSINESS=""
STRIPE_PAYMENT_LINK_ENTERPRISE=""

# Optional seed controls. In production, demo seeding is blocked unless explicitly enabled.
ALLOW_DEMO_SEED="false"
SEED_ADMIN_EMAIL="admin@your-domain.com"
SEED_LEGAL_EMAIL="legal@your-domain.com"
SEED_INTERMEDIARY_EMAIL="intermediary@your-domain.com"
SEED_ADMIN_PASSWORD="replace-with-a-long-random-password"
